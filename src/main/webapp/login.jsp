<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><%--
    ============================================================
    login.jsp — 登录/注册页面
    
    页面功能：
    1. 提供用户登录和注册功能，采用双栏布局（左侧视觉区 + 右侧表单区）。
    2. 左侧展示系统品牌、标题和背景图，右侧为登录/注册表单卡片。
    3. 支持标签切换：登录 / 注册，通过 tabs 按钮切换表单内容。
    4. 登录成功后根据角色跳转：ADMIN → admin.jsp，USER → home.jsp。
    5. 注册成功后自动跳转首页。
    
    后端 API：
    - POST /api/auth/login — 用户登录。
    - POST /api/auth/register — 用户注册。
    ============================================================
--%>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>登录 - 智旅旅行</title><!-- 页面专属内联样式：布局、卡片、按钮、响应式等 -->
<style>*{box-sizing:border-box}body{margin:0;min-height:100vh;font-family:"Microsoft YaHei","Segoe UI",sans-serif;background:#f5f8fc;color:#1f2937}.login-shell{min-height:100vh;display:grid;grid-template-columns:1.1fr .9fr}.visual{padding:40px;color:#fff;background:linear-gradient(180deg,rgba(0,132,230,.84),rgba(7,28,51,.78)),url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1400&q=80') center/cover;display:flex;flex-direction:column;justify-content:space-between}.visual h1{font-size:46px;line-height:1.18}.card{width:min(520px,100%);background:#fff;border-radius:20px;padding:40px;box-shadow:0 28px 80px rgba(15,40,80,.12)}.pane{display:flex;align-items:center;justify-content:center;padding:36px}.tabs{display:grid;grid-template-columns:1fr 1fr;background:#eef6ff;border-radius:14px;padding:6px;margin-bottom:24px}.tabs button{border:0;border-radius:10px;background:transparent;color:#0b7de3;font-weight:900;padding:14px;cursor:pointer}.tabs button.active{background:#fff}label{display:block;margin-top:16px;font-weight:900}input{width:100%;padding:14px;border:1px solid #d6e3f0;border-radius:10px;margin-top:8px}.primary{width:100%;margin-top:26px;border:0;border-radius:10px;background:#0b8ff6;color:#fff;padding:15px;font-weight:900;cursor:pointer}.tips{margin-top:20px;background:#f8fbff;border:1px solid #e5edf6;border-radius:12px;padding:14px;color:#667085;line-height:1.8}.msg{color:#ef4444;font-weight:900;margin-top:12px}</style></head><body><div class="login-shell"><section class="visual"><div style="font-size:30px;font-weight:900">✦ 智旅旅行</div><div><h1>把路线、酒店和门票放进同一个旅程里</h1><p>登录后进入旅游推荐平台，查看智能路线、酒店房型、景点门票、旅游地图和订单状态。</p></div><div>多城精选 · AI规划 · 地图联动</div></section><section class="pane"><div class="card"><div class="tabs"><button id="loginTab" class="active" onclick="switchMode('login')">用户登录</button><button id="registerTab" onclick="switchMode('register')">新用户注册</button></div><h1 id="formTitle">用户登录</h1><p id="formDesc">登录后系统会根据账号权限自动进入对应页面。</p><label>用户名</label><input id="username" value="demo"><label>密码</label><input id="password" type="password" value="demo123"><div class="register-field" style="display:none"><label>手机</label><input id="phone"><label>邮箱</label><input id="email"></div><button id="submitButton" class="primary" onclick="submitForm()">登录系统</button><div id="msg" class="msg"></div><div class="tips">演示用户：<strong>demo / demo123</strong><br>管理账号：<strong>admin / admin123</strong><br>系统会按账号角色自动分流，无需手动选择身份。</div></div></section></div><script>const ctx='<%= ctx %>';let mode='login';function switchMode(m){mode=m;loginTab.classList.toggle('active',m==='login');registerTab.classList.toggle('active',m==='register');formTitle.textContent=m==='login'?'用户登录':'新用户注册';formDesc.textContent=m==='login'?'登录后系统会根据账号权限自动进入对应页面。':'创建普通用户账号，注册成功后自动进入旅游首页。';document.querySelectorAll('.register-field').forEach(x=>x.style.display=m==='register'?'block':'none');submitButton.textContent=m==='login'?'登录系统':'注册并进入系统';}async function submitForm(){const body={username:username.value,password:password.value,phone:phone?.value,email:email?.value};const r=await fetch(ctx+'/api/auth/'+(mode==='login'?'login':'register'),{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});const d=await r.json();if(d.code===200){const u=d.data||{};location.href=u.role==='ADMIN'?ctx+'/admin.jsp':ctx+'/home.jsp';}else msg.textContent=d.message||'操作失败';}</script>
<!-- 页面主体结束 -->
</body></html>