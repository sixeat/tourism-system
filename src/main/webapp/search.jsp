<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><%--
    ============================================================
    search.jsp — 全站搜索结果页面
    
    页面功能：
    1. 接收来自顶部搜索框的关键词（q 参数），展示全站搜索结果。
    2. 结果分类展示：城市、景点、酒店、美食、交通枢纽等。
    3. 每个结果支持点击进入详情页：酒店→hotels.jsp，景点→map.jsp，城市→routes.jsp。
    4. 支持进一步筛选和排序。
    
    后端 API：
    - GET /api/auth/me — 鉴权。
    - GET /api/search?keyword=xxx — 全站搜索接口（聚合多表数据）。
    ============================================================
--%>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>全站搜索 - 智旅旅行</title><link rel="stylesheet" href="<%= ctx %>/static/css/ctrip-shell.css?v=20260616-fixed"></head><body><div class="app-shell"><aside class="side-nav"><button class="menu-toggle" title="&#33756;&#21333;">&#9776;</button><a class="side-link " href="<%= ctx %>/home.jsp"><span class="side-icon">⌂</span>首页</a><a class="side-link " href="<%= ctx %>/routes.jsp"><span class="side-icon">▣</span>路线规划</a><a class="side-link " href="<%= ctx %>/hotels.jsp"><span class="side-icon">▣</span>酒店预订</a><a class="side-link " href="<%= ctx %>/tickets.jsp"><span class="side-icon">▤</span>门票·活动</a><a class="side-link " href="<%= ctx %>/map.jsp"><span class="side-icon">⌖</span>旅游地图</a><a class="side-link " href="<%= ctx %>/ai.jsp"><span class="side-icon">✦</span>AI行程助手</a><div class="side-divider"></div><a class="side-link " href="<%= ctx %>/orders.jsp"><span class="side-icon">☰</span>我的订单</a><a class="side-link " href="<%= ctx %>/profile.jsp"><span class="side-icon">☺</span>个人中心</a><button class="side-link" onclick="logout()"><span class="side-icon">&#8618;</span>退出登录</button></aside><main class="main-area"><header class="top-header"><a class="brand" href="<%= ctx %>/home.jsp"><span class="brand-mark">✦</span>智旅旅行</a><div class="global-search"><input id="topKeyword" placeholder="搜索任何旅游相关" onkeydown="if(event.key==='Enter')topSearch()"><button onclick="topSearch()">⌕</button></div><div class="top-actions"><span class="user-chip" id="userChip">用户中心</span><a href="<%= ctx %>/orders.jsp">我的订单</a><a href="<%= ctx %>/ai.jsp">联系客服</a><button onclick="logout()">退出</button></div></header><section class="page-content"><div class="hero-panel"><h1>全站搜索</h1><p>一次搜索城市、景点、酒店、美食、机场和火车站，并直接进入地图、订酒店、订门票或 AI 规划。</p></div><div class="panel"><div style="display:grid;grid-template-columns:1fr 100px;gap:10px"><input id="keyword" placeholder="例如：北京、故宫、酒店、美食、火车站" onkeydown="if(event.key==='Enter')doSearch()"><button class="primary" onclick="doSearch()">搜索</button></div><div class="action-row"><button class="secondary" data-type="ALL">全部结果</button><button class="secondary" data-type="CITY">城市</button><button class="secondary" data-type="景点">景点</button><button class="secondary" data-type="酒店">酒店</button><button class="secondary" data-type="美食">美食</button><button class="secondary" data-type="交通">机场/火车站</button></div></div><div id="results" class="result-grid"></div></section></main></div><script>const ctx='<%= ctx %>';async function ensureLogin(){const r=await fetch(ctx+'/api/auth/me');const d=await r.json();if(d.code!==200){location.href=ctx+'/login.jsp';return null;}const u=d.data||{};const c=document.getElementById('userChip');if(c)c.textContent='尊敬的，'+(u.username||'用户');return u;}async function logout(){await fetch(ctx+'/api/auth/logout',{method:'POST'});location.href=ctx+'/login.jsp';}function topSearch(){const kw=(document.getElementById('topKeyword')?.value||'上海').trim();location.href=ctx+'/search.jsp?q='+encodeURIComponent(kw||'上海');}function e(t){return String(t==null?'':t).replace(/[&<>"']/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));}function today(n=0){const d=new Date();d.setDate(d.getDate()+n);return d.toISOString().slice(0,10);}ensureLogin();const params=new URLSearchParams(location.search);keyword.value=params.get('q')||'';topKeyword.value=keyword.value;let all=[];let current='ALL';async function loadSource(){const rs=await Promise.all([fetch(ctx+'/api/map/points').then(r=>r.json()).catch(()=>({data:[]})),fetch(ctx+'/api/scenic/list').then(r=>r.json()).catch(()=>({data:[]}))]);const points=(rs[0].data||[]).map(x=>({type:x.pointType||'景点',title:x.pointName,city:x.city,desc:x.address||x.description}));const scenics=(rs[1].data||[]).map(x=>({type:'景点',title:x.scenicName,city:x.city,desc:x.description}));const cities=[...new Set(points.map(x=>x.city).filter(Boolean))].map(c=>({type:'CITY',title:c,city:c,desc:'热门目的地'}));all=[...cities,...points,...scenics];}function draw(){const kw=(keyword.value||'').trim().toLowerCase();const list=all.filter(x=>(current==='ALL'||x.type===current||(current==='交通'&&(x.type==='机场'||x.type==='火车站')))&&(!kw||[x.title,x.city,x.type,x.desc].join(' ').toLowerCase().includes(kw)));results.innerHTML=list.slice(0,60).map(x=>'<div class="card"><div class="title">'+e(x.title)+'</div><div class="muted">'+e(x.city||'')+' · '+e(x.type)+' · '+e(x.desc||'')+'</div><div class="action-row"><a class="primary" href="'+ctx+'/map.jsp?city='+encodeURIComponent(x.city||x.title)+'&q='+encodeURIComponent(x.title)+'">打开</a><a class="secondary" href="'+ctx+'/routes.jsp?city='+encodeURIComponent(x.city||x.title)+'">规划路线</a></div></div>').join('')||'<div class="card muted">没有找到结果，换个关键词试试。</div>';}function doSearch(){topKeyword.value=keyword.value;draw();}document.querySelectorAll('[data-type]').forEach(btn=>btn.onclick=()=>{current=btn.dataset.type;draw();});loadSource().then(draw);</script><script src="<%= ctx %>/static/js/global-search.js?v=20260616-fixed"></script>
<!-- 页面主体结束 -->
</body></html>