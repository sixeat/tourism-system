<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><%--
    ============================================================
    home.jsp — 旅游首页（用户主页面）
    
    页面功能：
    1. 登录后的用户主页面，展示酒店预订快捷入口、推荐路线、热门城市轮播等。
    2. 提供酒店搜索表单（城市、入住日期、退房日期、人数），快速跳转到酒店预订页。
    3. 展示系统推荐的热门旅游路线卡片，支持一键查看详情。
    4. 包含 Banner 广告位和底部提示信息。
    
    后端 API：
    - GET /api/auth/me — 鉴权，获取用户信息，未登录跳转 login.jsp。
    - POST /api/auth/logout — 退出登录。
    - GET /api/route/recommend — 获取推荐路线列表（首页展示用）。
    ============================================================
--%>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>首页 - 智旅旅行</title><link rel="stylesheet" href="<%= ctx %>/static/css/ctrip-shell.css?v=20260616-ctrip-home"><!-- 页面专属内联样式：布局、卡片、按钮、响应式等 -->
<style>.page-content{padding:20px 34px 44px}.home-wrap{display:grid;grid-template-columns:minmax(650px,1fr) 420px;gap:20px}.booking-card{background:linear-gradient(135deg,#6ec6ff,#eaf6ff);border:1px solid #cde8ff;border-radius:18px;padding:22px;box-shadow:0 16px 42px rgba(11,143,246,.12)}.booking-head{display:flex;align-items:center;justify-content:space-between;color:#fff;margin-bottom:16px}.booking-head h1{margin:0;font-size:32px;font-weight:900}.trust{font-size:20px;font-weight:900;color:#0788f7;background:rgba(255,255,255,.65);border-radius:999px;padding:8px 14px}.hotel-form{background:rgba(255,255,255,.94);border-radius:14px;padding:14px;display:grid;grid-template-columns:1.25fr .9fr .7fr .9fr;gap:1px;margin-bottom:12px}.hotel-form label{background:#fff;padding:12px;border-right:1px solid #e5edf6}.hotel-form label:last-child{border-right:0}.hotel-form input{border:0;margin:0;padding:6px 0;font-size:20px;font-weight:900}.hotel-form small{display:block;color:#667085;margin-bottom:4px}.hotel-row{display:grid;grid-template-columns:1fr 1fr 1fr 180px;gap:12px}.hotel-row label{background:rgba(255,255,255,.96);border-radius:12px;padding:12px}.hotel-row input,.hotel-row select{border:0;margin:0;padding:6px 0;font-size:18px;font-weight:900}.search-big{border:0;border-radius:12px;background:#0797f7;color:#fff;font-size:24px;font-weight:900;cursor:pointer}.banner{height:118px;border-radius:16px;overflow:hidden;margin-top:16px;background:linear-gradient(90deg,rgba(16,35,95,.95),rgba(26,74,180,.55)),url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1400&q=85') center/cover;color:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 28px}.banner h2{font-size:30px;margin:0}.quick-strip{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:16px}.quick-entry{height:86px;border:1px solid #d9e8f7;border-radius:16px;background:linear-gradient(135deg,#f2fbff,#fff);display:flex;align-items:center;justify-content:space-between;padding:0 22px;text-decoration:none;color:#0f172a;font-weight:900;font-size:22px}.quick-entry span{color:#667085;font-size:15px;font-weight:700}.side-promo{border-radius:18px;min-height:535px;padding:24px;color:#fff;background:linear-gradient(180deg,rgba(17,110,176,.25),rgba(2,23,43,.25)),url('https://images.unsplash.com/photo-1598887142487-38a98fcca5a3?auto=format&fit=crop&w=900&q=85') center/cover;box-shadow:0 16px 42px rgba(20,40,80,.12);position:relative;overflow:hidden}.side-promo h2{font-size:24px;margin:0 0 8px}.weather{font-size:18px;font-weight:900}.promo-list{position:absolute;right:18px;top:72px;display:grid;gap:10px;width:190px}.promo-mini{display:grid;grid-template-columns:58px 1fr;gap:8px;align-items:center;background:rgba(255,255,255,.28);border-radius:12px;padding:8px;backdrop-filter:blur(8px)}.promo-mini img{width:58px;height:48px;object-fit:cover;border-radius:8px}.promo-mini strong{display:block;font-size:13px}.promo-mini span{font-size:12px}.rank-badge{position:absolute;left:28px;bottom:70px;background:rgba(58,30,12,.82);border:1px solid rgba(255,255,255,.35);border-radius:18px;padding:14px 18px;font-size:26px;font-weight:900}.biz-ad{height:96px;border-radius:18px;background:linear-gradient(135deg,#0864e8,#1688f8);color:#fff;margin-top:20px;display:flex;align-items:center;padding:0 28px;box-shadow:0 16px 42px rgba(8,100,232,.2)}.biz-ad strong{font-size:28px}.recommend{margin-top:22px}.recommend-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}.recommend-head h2{margin:0;font-size:28px}.tabs{display:flex;gap:10px}.tabs button{border:1px solid #d6e8ff;background:#fff;color:#0b7de3;border-radius:8px;padding:9px 18px;font-weight:900;cursor:pointer}.tabs button.active{background:#eef6ff;border-color:#0b8ff6}.hotel-cards{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}.hotel-card{background:#fff;border:1px solid #e5edf6;border-radius:16px;overflow:hidden;box-shadow:0 12px 30px rgba(20,40,80,.06);text-decoration:none;color:inherit}.hotel-card img{height:170px;width:100%;object-fit:cover}.hotel-card-body{padding:14px}.stars{color:#ffb000;letter-spacing:2px}.score{display:inline-flex;background:#0b8ff6;color:#fff;border-radius:6px;padding:3px 7px;font-weight:900;margin-right:6px}.price-line{display:flex;justify-content:space-between;align-items:end;margin-top:10px}.price-line strong{color:#0788f7;font-size:26px}.flow-mini{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:18px}.flow-mini div{background:#fff;border:1px solid #e5edf6;border-radius:14px;padding:14px;font-weight:900}.flow-mini span{display:block;color:#667085;font-size:13px;font-weight:700;margin-top:6px}@media(max-width:1200px){.home-wrap{grid-template-columns:1fr}.side-promo{min-height:420px}.hotel-cards{grid-template-columns:repeat(2,1fr)}.hotel-form,.hotel-row{grid-template-columns:1fr 1fr}.search-big{height:58px}}@media(max-width:760px){.hotel-cards,.flow-mini,.quick-strip{grid-template-columns:1fr}.hotel-form,.hotel-row{grid-template-columns:1fr}}</style></head><body><div class="app-shell"><aside class="side-nav"><button class="menu-toggle" title="&#33756;&#21333;">&#9776;</button><a class="side-link active" href="<%= ctx %>/home.jsp"><span class="side-icon">⌂</span>首页</a><a class="side-link " href="<%= ctx %>/routes.jsp"><span class="side-icon">▣</span>路线规划</a><a class="side-link " href="<%= ctx %>/hotels.jsp"><span class="side-icon">▣</span>酒店预订</a><a class="side-link " href="<%= ctx %>/tickets.jsp"><span class="side-icon">▤</span>门票·活动</a><a class="side-link " href="<%= ctx %>/map.jsp"><span class="side-icon">⌖</span>旅游地图</a><a class="side-link " href="<%= ctx %>/ai.jsp"><span class="side-icon">✦</span>AI行程助手</a><div class="side-divider"></div><a class="side-link " href="<%= ctx %>/orders.jsp"><span class="side-icon">☰</span>我的订单</a><a class="side-link " href="<%= ctx %>/profile.jsp"><span class="side-icon">☺</span>个人中心</a><button class="side-link" onclick="logout()"><span class="side-icon">&#8618;</span>退出登录</button></aside><main class="main-area"><header class="top-header"><a class="brand" href="<%= ctx %>/home.jsp"><span class="brand-mark">✦</span>智旅旅行</a><div class="global-search"><input id="topKeyword" placeholder="搜索任何旅游相关" onkeydown="if(event.key==='Enter')topSearch()"><button onclick="topSearch()">⌕</button></div><div class="top-actions"><span class="user-chip" id="userChip">用户中心</span><a href="<%= ctx %>/orders.jsp">我的订单</a><a href="<%= ctx %>/ai.jsp">联系客服</a><button onclick="logout()">退出</button></div></header><section class="page-content"><div class="home-wrap"><div><section class="booking-card"><div class="booking-head"><h1>预订酒店</h1><div class="trust">安心订 · 放心住</div></div><div class="hotel-form"><label><small>目的地/酒店名称</small><input id="city" value="上海"></label><label><small>入住</small><input id="checkIn" type="date"></label><label><small>住几晚</small><input id="nights" type="number" value="1"></label><label><small>退房</small><input id="checkOut" type="date"></label></div><div class="hotel-row"><label><small>房间及住客</small><select id="guest"><option>1间，1位</option><option>1间，2位</option><option>2间，4位</option></select></label><label><small>酒店级别</small><select id="level"><option>不限</option><option>四星级</option><option>五星级</option><option>精品民宿</option></select></label><label><small>关键词（选填）</small><input id="keyword" placeholder="景点/商圈/酒店名"></label><button class="search-big" onclick="goHotelSearch()">⌕ 搜索</button></div></section><div class="banner"><div><h2>酒店超品 · 旅居狂欢</h2><p>多城精选，路线、酒店、门票一站搞定</p></div><button class="primary" onclick="goRoutes()">生成路线</button></div><div class="quick-strip"><a class="quick-entry" href="<%= ctx %>/ai.jsp">AI行程助手 <span>一站式打造完美旅程 ›</span></a><a class="quick-entry" href="<%= ctx %>/map.jsp">旅游地图 <span>探索 · 好去处 ›</span></a></div></div><aside><section class="side-promo"><h2>南京必住酒店攻略</h2><div class="weather">21℃~29℃</div><div class="promo-list"><div class="promo-mini"><img src="https://images.unsplash.com/photo-1564501049412-61c2a3083791?auto=format&fit=crop&w=200&q=80"><div><strong>园博园悦榕庄</strong><span>¥2697.0起</span></div></div><div class="promo-mini"><img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?auto=format&fit=crop&w=200&q=80"><div><strong>璞樾酒店</strong><span>¥805.0起</span></div></div><div class="promo-mini"><img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=200&q=80"><div><strong>园博园英迪格</strong><span>¥693.0起</span></div></div></div><div class="rank-badge">智旅榜单<br><small>解决旅行选择题 ›</small></div></section><div class="biz-ad"><div><strong>智旅商旅.</strong><br>下一站企业差旅服务平台</div></div></aside></div><section class="recommend"><div class="recommend-head"><h2>酒店<span style="color:#ff7a00">推荐</span></h2><div class="tabs"><button class="active" onclick="selectCity('上海')">上海</button><button onclick="selectCity('北京')">北京</button><button onclick="selectCity('广州')">广州</button><button onclick="selectCity('三亚')">三亚</button><button onclick="selectCity('杭州')">更多</button></div></div><div class="hotel-cards"><a class="hotel-card" href="<%= ctx %>/hotels.jsp?city=上海"><img src="https://images.unsplash.com/photo-1564501049412-61c2a3083791?auto=format&fit=crop&w=700&q=80"><div class="hotel-card-body"><h3>上海张江 CitiGO 欢阁酒店</h3><div class="stars">◆◆◆◆</div><p><span class="score">4.9</span>超棒 2409条点评</p><div class="price-line"><span>近地铁/商圈</span><strong>¥707</strong></div></div></a><a class="hotel-card" href="<%= ctx %>/hotels.jsp?city=上海"><img src="https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?auto=format&fit=crop&w=700&q=80"><div class="hotel-card-body"><h3>城际上海徐家汇中心酒店</h3><div class="stars">◆◆◆◆</div><p><span class="score">4.7</span>超棒 4592条点评</p><div class="price-line"><span>商务优选</span><strong>¥698</strong></div></div></a><a class="hotel-card" href="<%= ctx %>/hotels.jsp?city=上海"><img src="https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=700&q=80"><div class="hotel-card-body"><h3>桔子水晶上海北外滩酒店</h3><div class="stars">◆◆◆◆</div><p><span class="score">4.8</span>超棒 3894条点评</p><div class="price-line"><span>江景夜游</span><strong>¥809</strong></div></div></a></div><div class="flow-mini"><div>AI需求输入<span>预算、兴趣、天数</span></div><div>路线规划<span>推荐算法生成</span></div><div>酒店/门票<span>房态和库存查询</span></div><div>统一订单<span>支付、取消、售后</span></div></div></section></section></main></div><script>const ctx='<%= ctx %>';async function ensureLogin(){const r=await fetch(ctx+'/api/auth/me');const d=await r.json();if(d.code!==200){location.href=ctx+'/login.jsp';return null;}const u=d.data||{};userChip.textContent='尊敬的，'+(u.username||'用户');return u;}async function logout(){await fetch(ctx+'/api/auth/logout',{method:'POST'});location.href=ctx+'/login.jsp';}function pad(n){return String(n).padStart(2,'0')}function fmt(d){return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())}function initDates(){const a=new Date();const b=new Date();b.setDate(a.getDate()+1);checkIn.value=fmt(a);checkOut.value=fmt(b)}function topSearch(){const kw=(topKeyword.value||city.value||'上海').trim();location.href=ctx+'/search.jsp?q='+encodeURIComponent(kw)}function goHotelSearch(){location.href=ctx+'/hotels.jsp?city='+encodeURIComponent(city.value||'上海')+'&keyword='+encodeURIComponent(keyword.value||'')}function goRoutes(){location.href=ctx+'/routes.jsp?city='+encodeURIComponent(city.value||'上海')+'&budget=1888&days=3'}function selectCity(c){city.value=c;goHotelSearch()}ensureLogin();initDates();</script><script src="<%= ctx %>/static/js/global-search.js?v=20260616-ctrip-home"></script>
<!-- 页面主体结束 -->
</body></html>