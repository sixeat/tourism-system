<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>旅游地图 - 智旅旅行</title><link rel="stylesheet" href="<%= ctx %>/static/css/ctrip-shell.css?v=20260616-fixed"><style>.map-layout{display:grid;grid-template-columns:390px 1fr;gap:18px;height:calc(100vh - 170px);min-height:620px}.map-side{overflow:auto}.map-canvas{position:relative;overflow:hidden;border-radius:24px;background:#dcecf8;border:1px solid #d9e8f7;box-shadow:0 12px 30px rgba(20,40,80,.08)}#amap{position:absolute;inset:0}.map-empty{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;text-align:center;color:#526071;background:linear-gradient(135deg,#eef6ff,#e8f7ff)}.filter-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}.filter-row button.active{background:#0b8ff6;color:#fff}.point-card{cursor:pointer}.point-card.active{border-color:#0b8ff6;box-shadow:0 16px 40px rgba(11,143,246,.16)}.point-meta{display:flex;justify-content:space-between;gap:10px}.badge{display:inline-flex;padding:4px 9px;border-radius:999px;background:#eef6ff;color:#0b7de3;font-weight:900;font-size:12px}.route-strip{position:absolute;left:18px;right:18px;bottom:18px;z-index:5;background:rgba(255,255,255,.94);border-radius:18px;padding:14px;box-shadow:0 14px 40px rgba(15,40,80,.18)}@media(max-width:1100px){.map-layout{grid-template-columns:1fr;height:auto}.map-canvas{height:560px}}</style><script src="<%= ctx %>/static/js/amap-config.js?v=20260617-safe"></script><script src="<%= ctx %>/static/js/amap-config.local.js?v=20260617-local"></script></head><body><div class="app-shell"><aside class="side-nav"><button class="menu-toggle" title="&#33756;&#21333;">&#9776;</button><a class="side-link " href="<%= ctx %>/home.jsp"><span class="side-icon">⌂</span>首页</a><a class="side-link " href="<%= ctx %>/routes.jsp"><span class="side-icon">▣</span>路线规划</a><a class="side-link " href="<%= ctx %>/hotels.jsp"><span class="side-icon">▣</span>酒店预订</a><a class="side-link " href="<%= ctx %>/tickets.jsp"><span class="side-icon">▤</span>门票·活动</a><a class="side-link active" href="<%= ctx %>/map.jsp"><span class="side-icon">⌖</span>旅游地图</a><a class="side-link " href="<%= ctx %>/ai.jsp"><span class="side-icon">✦</span>AI行程助手</a><div class="side-divider"></div><a class="side-link " href="<%= ctx %>/orders.jsp"><span class="side-icon">☰</span>我的订单</a><a class="side-link " href="<%= ctx %>/profile.jsp"><span class="side-icon">☺</span>个人中心</a><button class="side-link" onclick="logout()"><span class="side-icon">&#8618;</span>退出登录</button></aside><main class="main-area"><header class="top-header"><a class="brand" href="<%= ctx %>/home.jsp"><span class="brand-mark">✦</span>智旅旅行</a><div class="global-search"><input id="topKeyword" placeholder="搜索任何旅游相关" onkeydown="if(event.key==='Enter')topSearch()"><button onclick="topSearch()">⌕</button></div><div class="top-actions"><span class="user-chip" id="userChip">用户中心</span><a href="<%= ctx %>/orders.jsp">我的订单</a><a href="<%= ctx %>/ai.jsp">联系客服</a><button onclick="logout()">退出</button></div></header><section class="page-content"><div class="hero-panel"><h1>旅游地图</h1><p>统一携程式左栏和顶栏，展示景点、酒店、美食、机场、火车站，并支持路线点位联动。</p></div><div class="filter-row"><input id="mapKeyword" placeholder="搜索城市、景点、酒店、美食" style="max-width:360px"><button class="secondary active" data-type="ALL">全部</button><button class="secondary" data-type="景点">景点</button><button class="secondary" data-type="酒店">酒店</button><button class="secondary" data-type="美食">美食</button><button class="secondary" data-type="机场">机场</button><button class="secondary" data-type="火车站">火车站</button><button class="secondary" onclick="clearRoute()">清空路线</button></div><div class="map-layout"><aside class="map-side"><div class="panel"><h2>目的地资源</h2><p class="muted" id="summary">正在加载地图点位...</p></div><div id="pointList"></div></aside><section class="map-canvas"><div id="amap"></div><div id="mapFallback" class="map-empty"><div><h2>地图加载中</h2><p>如果高德地图暂时不可用，左侧点位列表仍可用于演示。</p></div></div><div class="route-strip" id="routeStrip" style="display:none"></div></section></div></section></main></div><script>const ctx='<%= ctx %>';async function ensureLogin(){const r=await fetch(ctx+'/api/auth/me');const d=await r.json();if(d.code!==200){location.href=ctx+'/login.jsp';return null;}const u=d.data||{};const c=document.getElementById('userChip');if(c)c.textContent='尊敬的，'+(u.username||'用户');return u;}async function logout(){await fetch(ctx+'/api/auth/logout',{method:'POST'});location.href=ctx+'/login.jsp';}function topSearch(){const kw=(document.getElementById('topKeyword')?.value||'上海').trim();location.href=ctx+'/search.jsp?q='+encodeURIComponent(kw||'上海');}function e(t){return String(t==null?'':t).replace(/[&<>"']/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));}ensureLogin();const params=new URLSearchParams(location.search);const initialCity=params.get('city')||'';const initialQ=params.get('q')||'';const initialRoute=params.get('route')||'';const initialSpots=(params.get('spots')||'').split(',').map(x=>x.trim()).filter(Boolean);mapKeyword.value=initialQ||initialCity;let allPoints=[];let routePointIds=[];let currentType='ALL';let map=null;let markers=[];let routeLine=null;let routeMarkers=[];function typeIcon(t){return t==='酒店'?'酒':t==='美食'?'食':t==='机场'?'机':t==='火车站'?'站':'景';}function filtered(){const kw=(mapKeyword.value||'').trim().toLowerCase();const routeMode=initialSpots.length>0&&!kw&&currentType==='ALL';return allPoints.filter(p=>{const sameCity=!initialCity||p.city===initialCity;const inRoute=routePointIds.includes(String(p.id));return (routeMode?(sameCity||inRoute):(currentType==='ALL'||p.pointType===currentType))&&(!kw||[p.pointName,p.city,p.address,p.tags,p.description].join(' ').toLowerCase().includes(kw));});}async function loadPoints(){const r=await fetch(ctx+'/api/map/points');const d=await r.json();allPoints=d.data||[];drawList();initMap();if(initialSpots.length)drawRouteByNames(initialSpots);}function drawList(){const list=filtered();summary.textContent=initialSpots.length?('\u8def\u7ebf\u8054\u52a8\uff1a'+(initialRoute||'\u63a8\u8350\u8def\u7ebf')+'\uff0c\u5171\u5339\u914d '+routePointIds.length+' \u4e2a\u8def\u7ebf\u70b9\u3002'):('\u5171\u627e\u5230 '+list.length+' \u4e2a\u70b9\u4f4d\uff0c\u53ef\u70b9\u51fb\u5361\u7247\u5728\u5730\u56fe\u4e0a\u5b9a\u4f4d\u3002');pointList.innerHTML=list.map((p,i)=>{const routeIndex=routePointIds.indexOf(String(p.id));const isRoute=routeIndex>=0;return '<div class="card point-card '+(isRoute?'active':'')+'" data-id="'+p.id+'" onclick="focusPoint('+p.id+')"><div class="point-meta"><div class="title">'+(isRoute?('<span class="badge">\u8def\u7ebf'+(routeIndex+1)+'</span> '):'')+e(p.pointName)+'</div><span class="badge">'+e(p.pointType||'\u666f\u70b9')+'</span></div><div class="muted">'+e(p.city||'')+' &middot; '+e(p.address||'')+'</div><div class="muted">'+e(p.description||p.tags||'')+'</div><div class="action-row"><a class="secondary" href="'+ctx+'/routes.jsp?city='+encodeURIComponent(p.city||'')+'">\u89c4\u5212\u8def\u7ebf</a>'+(p.pointType==='\u9152\u5e97'?'<a class="secondary" href="'+ctx+'/hotels.jsp?city='+encodeURIComponent(p.city||'')+'">\u8ba2\u9152\u5e97</a>':'<a class="secondary" href="'+ctx+'/tickets.jsp?city='+encodeURIComponent(p.city||'')+'">\u770b\u95e8\u7968</a>')+'</div></div>';}).join('')||'<div class="card muted">\u6ca1\u6709\u5339\u914d\u7684\u70b9\u4f4d\u3002</div>';drawMarkers(list);if(routePointIds.length)highlightRouteCards();}function loadAmapScript(){const cfg=window.TOURISM_AMAP_CONFIG||{};if(!cfg.key){mapFallback.innerHTML='<div><h2>地图密钥未配置</h2><p>请在 static/js/amap-config.local.js 填写高德 Key。左侧点位列表仍可用于演示。</p></div>';return Promise.resolve(false);}if(cfg.securityJsCode)window._AMapSecurityConfig={securityJsCode:cfg.securityJsCode};return new Promise(resolve=>{const s=document.createElement('script');s.src='https://webapi.amap.com/maps?v=2.0&key='+encodeURIComponent(cfg.key);s.onload=()=>{initMap();if(initialSpots.length)drawRouteByNames(initialSpots);resolve(true);};s.onerror=()=>{mapFallback.innerHTML='<div><h2>地图加载失败</h2><p>请检查高德 Key、网络或安全密钥配置。</p></div>';resolve(false);};document.head.appendChild(s);});}function initMap(){if(map||!window.AMap)return;if(!allPoints.length)return;const first=allPoints.find(p=>p.longitude&&p.latitude)||{longitude:116.397,latitude:39.908};map=new AMap.Map('amap',{zoom:11,center:[Number(first.longitude),Number(first.latitude)],viewMode:'2D'});mapFallback.style.display='none';drawMarkers(filtered());if(initialSpots.length)drawRouteByNames(initialSpots);}function drawMarkers(list){if(!map)return;markers.forEach(m=>m.setMap(null));markers=[];list.filter(p=>p.longitude&&p.latitude).forEach(p=>{const marker=new AMap.Marker({position:[Number(p.longitude),Number(p.latitude)],title:p.pointName,label:{content:typeIcon(p.pointType),direction:'top'}});marker.on('click',()=>focusPoint(p.id));marker.setMap(map);markers.push(marker);});if(markers.length)map.setFitView(markers,false,[60,60,60,60]);}function focusPoint(id){const p=allPoints.find(x=>String(x.id)===String(id));if(!p)return;document.querySelectorAll('.point-card').forEach(x=>x.classList.toggle('active',x.dataset.id==id));if(map&&p.longitude&&p.latitude){map.setZoomAndCenter(15,[Number(p.longitude),Number(p.latitude)]);new AMap.InfoWindow({content:'<div style="padding:6px 4px"><strong>'+e(p.pointName)+'</strong><br>'+e(p.pointType||'')+' · '+e(p.address||'')+'</div>'}).open(map,[Number(p.longitude),Number(p.latitude)]);}}function matchRoutePoint(name){const key=String(name||'').trim();if(!key)return null;return allPoints.find(p=>p.city===initialCity&&p.pointName===key)||allPoints.find(p=>p.city===initialCity&&p.pointName&&p.pointName.includes(key))||allPoints.find(p=>p.pointName&&p.pointName.includes(key))||allPoints.find(p=>key.includes(p.pointName));}function highlightRouteCards(){document.querySelectorAll('.point-card').forEach(card=>card.classList.toggle('active',routePointIds.includes(String(card.dataset.id))));}function drawRouteByNames(names){const seen=new Set();const points=names.map(matchRoutePoint).filter(Boolean).filter(p=>{const id=String(p.id);if(seen.has(id))return false;seen.add(id);return true;});routePointIds=points.map(p=>String(p.id));if(!points.length){routeStrip.style.display='block';routeStrip.innerHTML='<strong>\u8def\u7ebf\u8054\u52a8\u5931\u8d25\uff1a</strong>\u6ca1\u6709\u5728\u5730\u56fe\u70b9\u4f4d\u5e93\u4e2d\u5339\u914d\u5230 '+names.map(e).join('\u3001');return;}routeStrip.style.display='block';routeStrip.innerHTML='<strong>'+(initialRoute?e(initialRoute):'\u63a8\u8350\u8def\u7ebf')+'</strong><br>'+points.map((p,i)=>'<span class="badge">'+(i+1)+'</span> '+e(p.pointName)).join(' \u2192 ');drawList();highlightRouteCards();if(!map)return;const path=points.filter(p=>p.longitude&&p.latitude).map(p=>[Number(p.longitude),Number(p.latitude)]);if(routeLine)routeLine.setMap(null);routeMarkers.forEach(m=>m.setMap(null));routeMarkers=[];if(path.length>1){routeLine=new AMap.Polyline({path,strokeColor:'#0b8ff6',strokeWeight:8,strokeOpacity:.95,strokeStyle:'solid'});routeLine.setMap(map);}points.filter(p=>p.longitude&&p.latitude).forEach((p,i)=>{const marker=new AMap.Marker({position:[Number(p.longitude),Number(p.latitude)],title:(i+1)+'. '+p.pointName,label:{content:String(i+1),direction:'top'}});marker.setMap(map);routeMarkers.push(marker);});if(path.length)map.setFitView(routeLine?[routeLine,...routeMarkers]:routeMarkers,false,[90,90,90,90]);}function clearRoute(){if(routeLine)routeLine.setMap(null);routeMarkers.forEach(m=>m.setMap(null));routeMarkers=[];routePointIds=[];routeStrip.style.display='none';drawList();}document.querySelectorAll('[data-type]').forEach(btn=>btn.onclick=()=>{currentType=btn.dataset.type;document.querySelectorAll('[data-type]').forEach(b=>b.classList.remove('active'));btn.classList.add('active');drawList();if(routePointIds.length)drawRouteByNames(initialSpots);});mapKeyword.addEventListener('input',()=>{drawList();if(routePointIds.length)highlightRouteCards();});loadPoints().then(loadAmapScript);</script><script src="<%= ctx %>/static/js/global-search.js?v=20260616-fixed"></script></body></html>