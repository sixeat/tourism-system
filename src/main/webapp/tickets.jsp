<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><%--
    ============================================================
    tickets.jsp — 门票预订页面
    
    页面功能：
    1. 按城市展示景点列表，支持按分类和关键词筛选。
    2. 每个景点卡片展示：名称、城市、分类、评分、描述、价格。
    3. 支持查看景点下的所有可售门票（成人票、学生票等），展示库存和起售日期。
    4. 选择门票后显示汇总（票种、游玩日期、数量、预计总价），支持提交门票订单。
    5. 支持无限滚动加载（IntersectionObserver），默认每页加载 6 个景点。
    6. 门票库存不足或未到起售日期时，按钮禁用并显示原因。
    
    后端 API：
    - GET /api/auth/me — 鉴权。
    - GET /api/scenic/list?city=xxx — 获取城市景点列表。
    - GET /api/ticket/list?scenicId=xxx — 获取景点下的门票列表。
    - POST /api/order/ticket/create — 创建门票订单（传入 ticketId, visitDate, quantity）。
    ============================================================
--%>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>&#38376;&#31080;&#39044;&#35746; - &#26234;&#26053;&#26053;&#34892;</title><link rel="stylesheet" href="<%= ctx %>/static/css/ctrip-shell.css?v=20260616-ticket-lazy"><!-- 页面专属内联样式：布局、卡片、按钮、响应式等 -->
<style>.ticket-query{background:#fff;border:1px solid #e5edf6;border-radius:22px;padding:22px;box-shadow:0 12px 30px rgba(20,40,80,.06);margin-bottom:20px}.empty-state{min-height:320px;border:1px dashed #cfe4fb;border-radius:22px;background:linear-gradient(135deg,#f8fbff,#fff);display:flex;align-items:center;justify-content:center;text-align:center;color:#667085}.empty-state strong{display:block;color:#0f172a;font-size:26px;margin-bottom:10px}.result-toolbar{display:none;background:#fff;border:1px solid #e5edf6;border-radius:20px;padding:16px;margin-bottom:16px;box-shadow:0 10px 26px rgba(20,40,80,.05)}.toolbar-row{display:grid;grid-template-columns:1fr 160px 180px;gap:12px;margin-top:12px}.tag-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}.tag-row button.active{background:#0b8ff6;color:#fff}.scenic-grid{display:grid;grid-template-columns:repeat(3,minmax(280px,1fr));gap:18px}.ticket-card{min-height:250px}.ticket-box{margin-top:12px;display:grid;gap:10px}.ticket-option{border:1px solid #e5edf6;border-radius:14px;background:#f8fbff;padding:12px}.ticket-option.selected{border-color:#0b8ff6;background:#eef8ff}.ticket-option.disabled{opacity:.55;background:#f8fafc}.ticket-date-line{margin-top:8px;color:#0b7de3;font-weight:900}.ticket-reason{color:#f97316;font-weight:900}.load-sentinel{height:54px;display:flex;align-items:center;justify-content:center;color:#667085}@media(max-width:1200px){.scenic-grid{grid-template-columns:repeat(2,minmax(260px,1fr))}.toolbar-row{grid-template-columns:1fr}}@media(max-width:760px){.scenic-grid{grid-template-columns:1fr}}</style></head><body><div class="app-shell"><aside class="side-nav"><button class="menu-toggle" title="&#33756;&#21333;">&#9776;</button><a class="side-link " href="<%= ctx %>/home.jsp"><span class="side-icon">&#8962;</span>&#39318;&#39029;</a><a class="side-link " href="<%= ctx %>/routes.jsp"><span class="side-icon">&#9635;</span>&#36335;&#32447;&#35268;&#21010;</a><a class="side-link " href="<%= ctx %>/hotels.jsp"><span class="side-icon">&#9635;</span>&#37202;&#24215;&#39044;&#35746;</a><a class="side-link active" href="<%= ctx %>/tickets.jsp"><span class="side-icon">&#9636;</span>&#38376;&#31080;&#183;&#27963;&#21160;</a><a class="side-link " href="<%= ctx %>/map.jsp"><span class="side-icon">&#8982;</span>&#26053;&#28216;&#22320;&#22270;</a><a class="side-link " href="<%= ctx %>/ai.jsp"><span class="side-icon">&#10022;</span>AI&#34892;&#31243;&#21161;&#25163;</a><div class="side-divider"></div><a class="side-link " href="<%= ctx %>/orders.jsp"><span class="side-icon">&#9776;</span>&#25105;&#30340;&#35746;&#21333;</a><a class="side-link " href="<%= ctx %>/profile.jsp"><span class="side-icon">&#9786;</span>&#20010;&#20154;&#20013;&#24515;</a><button class="side-link" onclick="logout()"><span class="side-icon">&#8618;</span>&#36864;&#20986;&#30331;&#24405;</button></aside><main class="main-area"><header class="top-header"><a class="brand" href="<%= ctx %>/home.jsp"><span class="brand-mark">&#10022;</span>&#26234;&#26053;&#26053;&#34892;</a><div class="global-search"><input id="topKeyword" placeholder="&#25628;&#32034;&#20219;&#20309;&#26053;&#28216;&#30456;&#20851;" onkeydown="if(event.key==='Enter')topSearch()"><button onclick="topSearch()">&#8981;</button></div><div class="top-actions"><span class="user-chip" id="userChip">&#29992;&#25143;&#20013;&#24515;</span><a href="<%= ctx %>/orders.jsp">&#25105;&#30340;&#35746;&#21333;</a><a href="<%= ctx %>/ai.jsp">&#32852;&#31995;&#23458;&#26381;</a><button onclick="logout()">&#36864;&#20986;</button></div></header><section class="page-content"><div class="hero-panel"><h1>&#26223;&#28857;&#38376;&#31080;&#39044;&#35746;</h1><p>&#20808;&#36873;&#25321;&#22478;&#24066;&#21644;&#28216;&#29609;&#26085;&#26399;&#65292;&#26597;&#35810;&#21518;&#20877;&#23637;&#31034;&#23545;&#24212;&#22478;&#24066;&#30340;&#26223;&#28857;&#12289;&#31080;&#31181;&#21644;&#24211;&#23384;&#12290;</p></div><div class="ticket-query"><div class="form-grid"><label>&#22478;&#24066;<input id="city" value="&#19978;&#28023;"></label><label>&#28216;&#29609;&#26085;&#26399;<input id="visitDate" type="date"></label><label>&#25968;&#37327;<input id="quantity" type="number" min="1" value="1"></label></div><div class="action-row"><button class="primary" onclick="loadScenics(true)">&#26597;&#35810;&#26223;&#28857;</button><button class="secondary" onclick="createTicketOrder()">&#25552;&#20132;&#38376;&#31080;&#35746;&#21333;</button></div><div id="selectedTip" class="muted">&#35831;&#20808;&#26597;&#35810;&#26223;&#28857;&#65292;&#20877;&#36873;&#25321;&#20855;&#20307;&#31080;&#31181;&#12290;</div></div><div id="emptyState" class="empty-state"><div><strong>&#128506; &#35831;&#20808;&#26597;&#35810;&#26223;&#28857;</strong><p>&#36873;&#25321;&#22478;&#24066;&#21644;&#28216;&#29609;&#26085;&#26399;&#21518;&#65292;&#28857;&#20987;&#8220;&#26597;&#35810;&#26223;&#28857;&#8221;&#12290;</p><p>&#31995;&#32479;&#21482;&#20250;&#23637;&#31034;&#24403;&#21069;&#22478;&#24066;&#30340;&#26223;&#28857;&#65292;&#25903;&#25345;&#25628;&#32034;&#12289;&#20998;&#31867;&#12289;&#25490;&#24207;&#21644;&#28378;&#21160;&#21152;&#36733;&#12290;</p></div></div><div id="resultToolbar" class="result-toolbar"><strong id="resultSummary">&#26597;&#35810;&#32467;&#26524;</strong><div class="toolbar-row"><input id="scenicKeyword" placeholder="&#25628;&#32034;&#26223;&#28857;&#21517;&#31216;..." oninput="applyFilters(true)"><select id="categoryFilter" onchange="applyFilters(true)"><option value="ALL">&#20840;&#37096;&#20998;&#31867;</option></select><select id="sortMode" onchange="applyFilters(true)"><option value="score">&#35780;&#20998;&#20174;&#39640;&#21040;&#20302;</option><option value="priceAsc">&#20215;&#26684;&#20174;&#20302;&#21040;&#39640;</option><option value="priceDesc">&#20215;&#26684;&#20174;&#39640;&#21040;&#20302;</option><option value="popularity">&#20154;&#27668;&#20174;&#39640;&#21040;&#20302;</option></select></div><div id="tagRow" class="tag-row"></div></div><div id="scenics" class="scenic-grid"></div><div id="loadSentinel" class="load-sentinel"></div></section></main></div><script>const ctx='<%= ctx %>';
async function ensureLogin(){const r=await fetch(ctx+'/api/auth/me');const d=await r.json();if(d.code!==200){location.href=ctx+'/login.jsp';return null;}const u=d.data||{};const c=document.getElementById('userChip');if(c)c.textContent='\u5c0a\u656c\u7684\uff0c'+(u.username||'\u7528\u6237');return u;}
async function logout(){await fetch(ctx+'/api/auth/logout',{method:'POST'});location.href=ctx+'/login.jsp';}
function topSearch(){const kw=(document.getElementById('topKeyword')?.value||'\u4e0a\u6d77').trim();location.href=ctx+'/search.jsp?q='+encodeURIComponent(kw||'\u4e0a\u6d77');}
function dateValue(v){if(Array.isArray(v)){return v[0]+'-'+String(v[1]).padStart(2,'0')+'-'+String(v[2]).padStart(2,'0');}return String(v||'');}function e(t){return String(t==null?'':t).replace(/[&<>"']/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));}
function today(n=0){const d=new Date();d.setDate(d.getDate()+n);return d.toISOString().slice(0,10);}
ensureLogin();
const params=new URLSearchParams(location.search);city.value=params.get('city')||city.value;visitDate.value=today(2);visitDate.min=today(0);visitDate.addEventListener('change',()=>{selectedTicket=null;selectedTip.textContent='游玩日期已更新，请重新查看票种。';document.querySelectorAll('.ticket-box').forEach(x=>x.innerHTML='');});
let selectedTicket=null, allScenics=[], filteredScenics=[], visibleCount=0, currentCategory='ALL';const pageSize=6;let observer=null;
function normalizeCity(v){return String(v||'').trim();}
async function loadScenics(reset=true){selectedTicket=null;selectedTip.textContent='\u6b63\u5728\u67e5\u8be2\u666f\u70b9...';emptyState.style.display='none';resultToolbar.style.display='block';scenics.innerHTML='<div class="card muted">&#27491;&#22312;&#21152;&#36733;&#24403;&#21069;&#22478;&#24066;&#26223;&#28857;...</div>';loadSentinel.textContent='';const targetCity=normalizeCity(city.value);const r=await fetch(ctx+'/api/scenic/list?city='+encodeURIComponent(targetCity));const d=await r.json();const raw=d.data||[];allScenics=raw.filter(s=>normalizeCity(s.city)===targetCity);currentCategory='ALL';buildCategories();applyFilters(true);selectedTip.textContent='\u8bf7\u9009\u62e9\u95e8\u7968\u3002';}
function buildCategories(){const cats=['ALL',...new Set(allScenics.map(s=>s.category||'\u666f\u70b9'))];categoryFilter.innerHTML=cats.map(c=>'<option value="'+e(c)+'">'+(c==='ALL'?'\u5168\u90e8\u5206\u7c7b':e(c))+'</option>').join('');tagRow.innerHTML=cats.map(c=>'<button class="secondary '+(c===currentCategory?'active':'')+'" data-cat="'+e(c)+'">'+(c==='ALL'?'\u5168\u90e8':e(c))+'</button>').join('');tagRow.querySelectorAll('button').forEach(btn=>btn.onclick=()=>selectCategory(btn.dataset.cat));}
function selectCategory(c){currentCategory=c;categoryFilter.value=c;tagRow.querySelectorAll('button').forEach(b=>b.classList.toggle('active',b.dataset.cat===c));applyFilters(true);}
function applyFilters(reset=true){const kw=(scenicKeyword.value||'').trim().toLowerCase();const cat=categoryFilter.value||currentCategory||'ALL';currentCategory=cat;if(tagRow)tagRow.querySelectorAll('button').forEach(b=>b.classList.toggle('active',b.dataset.cat===cat));filteredScenics=allScenics.filter(s=>(cat==='ALL'||s.category===cat)&&(!kw||[s.scenicName,s.category,s.tags,s.description].join(' ').toLowerCase().includes(kw)));const sort=sortMode.value;filteredScenics.sort((a,b)=>sort==='priceAsc'?Number(a.price||0)-Number(b.price||0):sort==='priceDesc'?Number(b.price||0)-Number(a.price||0):sort==='popularity'?Number(b.popularity||0)-Number(a.popularity||0):Number(b.score||0)-Number(a.score||0));resultSummary.textContent='\u5171\u627e\u5230 '+filteredScenics.length+' '+e(city.value)+'\u4e2a\u666f\u70b9';if(reset)visibleCount=0;renderMore(true);}
function renderMore(force=false){if(visibleCount>=filteredScenics.length&&!force)return;visibleCount=Math.min(visibleCount+pageSize,filteredScenics.length);const list=filteredScenics.slice(0,visibleCount);scenics.innerHTML=list.map(renderScenic).join('')||'<div class="card muted">&#27809;&#26377;&#25214;&#21040;&#21305;&#37197;&#30340;&#26223;&#28857;&#12290;</div>';loadSentinel.textContent=visibleCount<filteredScenics.length?'\u4e0b\u6ed1\u7ee7\u7eed\u52a0\u8f7d...':'\u5df2\u52a0\u8f7d\u5168\u90e8\u7ed3\u679c';}
function renderScenic(s){return '<div class="card ticket-card"><div class="title">'+e(s.scenicName)+'</div><div class="muted">'+e(s.city)+' &middot; '+e(s.category||'\u666f\u70b9')+' &middot; \u8bc4\u5206 '+(s.score||'-')+'</div><div class="muted">'+e(s.description||'')+'</div><div class="price">&yen;'+Number(s.price||0)+'<small>\u8d77</small></div><div class="action-row"><button class="primary" onclick="loadTickets('+Number(s.id)+')">\u67e5\u770b\u7968\u79cd</button><a class="secondary" href="'+ctx+'/map.jsp?city='+encodeURIComponent(s.city||city.value)+'&q='+encodeURIComponent(s.scenicName)+'">\u5730\u56fe\u5b9a\u4f4d</a></div><div id="tickets-'+Number(s.id)+'" class="ticket-box"></div></div>';}
async function loadTickets(scenicId){const box=document.getElementById('tickets-'+scenicId);box.innerHTML='<div class="muted">正在加载票种...</div>';const r=await fetch(ctx+'/api/ticket/list?scenicId='+scenicId);const d=await r.json();const list=d.data||[];box.innerHTML=list.map(t=>{const stock=Number(t.stock||0);const saleDate=dateValue(t.availableDate);const dateOk=!saleDate||visitDate.value>=saleDate;const disabled=stock<=0||!dateOk;const reason=stock<=0?'库存不足':(!dateOk?'未到起售日期':'可订');return '<div class="ticket-option '+(disabled?'disabled':'')+'" data-ticket-id="'+t.id+'"><strong>'+e(t.ticketName)+'</strong><div class="muted">库存 '+stock+' 张 &middot; 起售日期 '+(saleDate||'不限')+'</div><div class="ticket-date-line">本次游玩日期：'+e(visitDate.value)+'</div><div class="price">&yen;'+Number(t.price||0).toFixed(2)+'<small>/张</small></div><button class="secondary ticket-select" '+(disabled?'disabled':'')+' data-ticket-id="'+t.id+'" data-ticket-name="'+e(t.ticketName)+'" data-ticket-price="'+Number(t.price||0)+'" data-ticket-date="'+e(saleDate)+'">'+(disabled?reason:'选择门票')+'</button>'+(disabled?'<div class="ticket-reason">'+reason+'</div>':'')+'</div>';}).join('')||'<div class="muted">暂无可售票种。</div>';box.querySelectorAll('.ticket-select').forEach(btn=>btn.onclick=()=>selectTicket(Number(btn.dataset.ticketId),btn.dataset.ticketName,Number(btn.dataset.ticketPrice||0),btn.dataset.ticketDate));}
function selectTicket(id,name,price,date){selectedTicket={id,name,price:Number(price||0),date};document.querySelectorAll('.ticket-option').forEach(x=>x.classList.toggle('selected',String(x.dataset.ticketId)===String(id)));const count=Math.max(1,Number(quantity.value||1));selectedTip.textContent='已选择：'+name+' · 游玩日期 '+visitDate.value+' · 数量 '+count+' 张 · 预计 ¥'+(selectedTicket.price*count).toFixed(2);}
async function createTicketOrder(){if(!visitDate.value){alert('请选择游玩日期');return;}const count=Math.max(1,Number(quantity.value||1));if(!selectedTicket){alert('请先选择门票');return;}if(selectedTicket.date&&visitDate.value<selectedTicket.date){alert('当前门票还未到起售日期，请重新选择游玩日期');return;}if(!confirm('确认提交门票订单？\n票种：'+selectedTicket.name+'\n游玩日期：'+visitDate.value+'\n数量：'+count+' 张\n预计总价：¥'+(selectedTicket.price*count).toFixed(2)))return;const r=await fetch(ctx+'/api/order/ticket/create',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ticketId:selectedTicket.id,visitDate:visitDate.value,quantity:count})});const d=await r.json();alert(d.message||'已创建门票订单');if(d.code===200)location.href=ctx+'/orders.jsp';}
observer=new IntersectionObserver(entries=>{if(entries.some(x=>x.isIntersecting))renderMore(false);},{rootMargin:'160px'});observer.observe(loadSentinel);if(params.get('city'))loadScenics(true);
</script><script src="<%= ctx %>/static/js/global-search.js?v=20260616-ticket-lazy"></script>
<!-- 页面主体结束 -->
</body></html>