<?xml version="1.0" encoding="UTF-8"?>
<!-- ========================================================== -->
<!--  Web 应用部署描述符（Deployment Descriptor）                 -->
<!--  文件路径：WEB-INF/web.xml                                   -->
<!--  作用：Java EE / Jakarta EE 标准 Web 应用配置文件，定义 Servlet 容器（如 Tomcat）
       在启动和运行时需要加载的 Listener、Servlet、Filter、上下文参数等核心组件。
       遵循 Servlet 4.0 规范（web-app_4_0.xsd）。                     -->
<!-- ========================================================== -->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ---------------------------------------------------------- -->
    <!--  显示名称                                                    -->
    <!-- ---------------------------------------------------------- -->
    <!-- display-name：Web 应用在 Servlet 容器管理界面（如 Tomcat Manager）中显示的名称，
         便于运维人员识别该应用 -->
    <display-name>tourism-system</display-name>

    <!-- ---------------------------------------------------------- -->
    <!--  上下文参数（Context Parameters）                            -->
    <!-- ---------------------------------------------------------- -->
    <!-- context-param：定义全局初始化参数，对整个 Web 应用的所有组件可见，
         在 ServletContext 启动时即被加载，可通过 ServletContext.getInitParameter() 获取。
         此处指定 Spring 根应用上下文的 XML 配置文件位置，用于构建业务层（Service/DAO）的 Bean 容器。 -->
    <context-param>
        <!-- 参数名：Spring 容器约定名称，ContextLoaderListener 默认会读取此名称的参数 -->
        <param-name>contextConfigLocation</param-name>
        <!-- 参数值：Spring 根配置文件路径，classpath 表示从类路径加载，
             spring-context.xml 中定义了 Service、DAO、事务、数据源等基础设施 Bean -->
        <param-value>classpath:spring/spring-context.xml</param-value>
    </context-param>

    <!-- ---------------------------------------------------------- -->
    <!--  监听器（Listeners）——Servlet 生命周期钩子                 -->
    <!-- ---------------------------------------------------------- -->
    <!-- listener：在 Servlet 容器启动或关闭时触发特定事件，
         常用于初始化全局资源、加载框架上下文等。这里使用 Spring 的 ContextLoaderListener
         在 Web 应用启动时自动加载并初始化 Spring 根应用上下文（Root ApplicationContext），
         将其绑定到 ServletContext 中，供整个 Web 应用共享。 -->
    <listener>
        <!-- listener-class：监听器的完整类路径，Spring 提供的标准实现 -->
        <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
    </listener>

    <!-- ---------------------------------------------------------- -->
    <!--  Servlet 定义与映射                                          -->
    <!-- ---------------------------------------------------------- -->
    <!-- servlet：定义一个 Servlet 组件，
         此处配置 Spring MVC 的核心前端控制器 DispatcherServlet，它是整个 MVC 架构的入口点，
         负责接收所有 HTTP 请求、调用处理器映射、执行拦截器、适配 Handler、渲染视图等完整流程。 -->
    <servlet>
        <!-- servlet-name：Servlet 的逻辑名称，必须在当前 web.xml 中唯一，后续 servlet-mapping 通过此名称关联 -->
        <servlet-name>springDispatcherServlet</servlet-name>
        <!-- servlet-class：Servlet 的完整类路径，Spring MVC 的核心分发器 -->
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>

        <!-- init-param：Servlet 初始化参数，仅在当前 Servlet 实例范围内有效，
             DispatcherServlet 启动时会根据此参数加载自己的 Spring MVC 子上下文，
             与上面的 Root ApplicationContext 形成父子容器关系，子容器可访问父容器的 Bean。 -->
        <init-param>
            <!-- contextConfigLocation：告知 DispatcherServlet 从何处加载 MVC 层配置文件 -->
            <param-name>contextConfigLocation</param-name>
            <!-- 配置值：spring-mvc.xml 中定义了 Controller、视图解析器、拦截器、注解驱动等 Web 层组件 -->
            <param-value>classpath:spring/spring-mvc.xml</param-value>
        </init-param>

        <!-- load-on-startup：Servlet 启动优先级，数值越小启动越早，
             设为 1 表示在 Web 应用启动时立即实例化并初始化该 Servlet，
             而不是等到第一次请求时才懒加载，减少首次请求的延迟。 -->
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!-- servlet-mapping：将 URL 请求路径映射到对应的 Servlet 实例上，
         所有符合 url-pattern 的请求都会由 springDispatcherServlet 处理。 -->
    <servlet-mapping>
        <!-- servlet-name：与上面 <servlet> 中的名称对应，建立映射关系 -->
        <servlet-name>springDispatcherServlet</servlet-name>
        <!-- url-pattern：匹配规则，"/" 表示拦截所有进入 Web 应用的请求（除 JSP 外），
             这是 RESTful 风格的常见配置，让 Spring MVC 完全接管 URL 路由。 -->
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <!-- ---------------------------------------------------------- -->
    <!--  过滤器（Filters）——请求/响应预处理                          -->
    <!-- ---------------------------------------------------------- -->
    <!-- filter：在请求到达 Servlet 之前或响应离开 Servlet 之后执行过滤逻辑，
         此处配置 Spring 提供的 CharacterEncodingFilter，用于统一设置请求和响应的字符编码，
         彻底解决中文参数乱码问题，是 Java Web 应用的标准最佳实践。 -->
    <filter>
        <!-- filter-name：过滤器的逻辑名称，必须在当前 web.xml 中唯一 -->
        <filter-name>encodingFilter</filter-name>
        <!-- filter-class：过滤器的完整类路径，Spring 内置的字符编码过滤器 -->
        <filter-class>org.springframework.web.filter.CharacterEncodingFilter</filter-class>

        <!-- 初始化参数：设置目标编码为 UTF-8，覆盖请求对象中的原有编码设置 -->
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <!-- 初始化参数：强制对请求和响应都应用上述编码设置，
             即使客户端已经声明了其他编码，也强制使用 UTF-8，确保前后端编码一致。 -->
        <init-param>
            <param-name>forceEncoding</param-name>
            <param-value>true</param-value>
        </init-param>
    </filter>

    <!-- filter-mapping：定义过滤器生效的 URL 范围，
         通常将编码过滤器置于最前面，对所有请求生效。 -->
    <filter-mapping>
        <!-- filter-name：与上面 <filter> 中的名称对应 -->
        <filter-name>encodingFilter</filter-name>
        <!-- url-pattern："/*" 表示匹配所有请求路径（包括静态资源和动态请求），
             确保无论访问何种资源，请求参数和响应内容都使用 UTF-8 编码。 -->
        <url-pattern>/*</url-pattern>
    </filter-mapping>
</web-app>
