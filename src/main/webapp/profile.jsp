<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>个人中心 - 智旅旅行</title><link rel="stylesheet" href="<%= ctx %>/static/css/ctrip-shell.css?v=20260616-fixed"></head><body><div class="app-shell"><aside class="side-nav"><button class="menu-toggle" title="&#33756;&#21333;">&#9776;</button><a class="side-link " href="<%= ctx %>/home.jsp"><span class="side-icon">⌂</span>首页</a><a class="side-link " href="<%= ctx %>/routes.jsp"><span class="side-icon">▣</span>路线规划</a><a class="side-link " href="<%= ctx %>/hotels.jsp"><span class="side-icon">▣</span>酒店预订</a><a class="side-link " href="<%= ctx %>/tickets.jsp"><span class="side-icon">▤</span>门票·活动</a><a class="side-link " href="<%= ctx %>/map.jsp"><span class="side-icon">⌖</span>旅游地图</a><a class="side-link " href="<%= ctx %>/ai.jsp"><span class="side-icon">✦</span>AI行程助手</a><div class="side-divider"></div><a class="side-link " href="<%= ctx %>/orders.jsp"><span class="side-icon">☰</span>我的订单</a><a class="side-link active" href="<%= ctx %>/profile.jsp"><span class="side-icon">☺</span>个人中心</a><button class="side-link" onclick="logout()"><span class="side-icon">&#8618;</span>退出登录</button></aside><main class="main-area"><header class="top-header"><a class="brand" href="<%= ctx %>/home.jsp"><span class="brand-mark">✦</span>智旅旅行</a><div class="global-search"><input id="topKeyword" placeholder="搜索任何旅游相关" onkeydown="if(event.key==='Enter')topSearch()"><button onclick="topSearch()">⌕</button></div><div class="top-actions"><span class="user-chip" id="userChip">用户中心</span><a href="<%= ctx %>/orders.jsp">我的订单</a><a href="<%= ctx %>/ai.jsp">联系客服</a><button onclick="logout()">退出</button></div></header><section class="page-content"><div class="hero-panel"><h1>个人中心</h1><p>管理账号资料、查看角色权限，并可随时进入 AI 行程助手。</p></div><div class="panel"><h2>账号资料</h2><div class="muted">用户名：<strong id="username">-</strong> · 权限：<strong id="role">-</strong></div><div class="form-grid"><label>手机<input id="phone"></label><label>邮箱<input id="email"></label><label>旧密码<input id="oldPassword" type="password"></label><label>新密码<input id="newPassword" type="password"></label></div><div class="action-row"><button class="primary" onclick="saveProfile()">保存资料</button><a class="secondary" href="<%= ctx %>/ai.jsp">咨询AI客服</a></div><div id="profileMsg" class="muted"></div></div></section></main></div><script>const ctx='<%= ctx %>';async function ensureLogin(){const r=await fetch(ctx+'/api/auth/me');const d=await r.json();if(d.code!==200){location.href=ctx+'/login.jsp';return null;}const u=d.data||{};const c=document.getElementById('userChip');if(c)c.textContent='尊敬的，'+(u.username||'用户');return u;}async function logout(){await fetch(ctx+'/api/auth/logout',{method:'POST'});location.href=ctx+'/login.jsp';}function topSearch(){const kw=(document.getElementById('topKeyword')?.value||'上海').trim();location.href=ctx+'/search.jsp?q='+encodeURIComponent(kw||'上海');}function e(t){return String(t==null?'':t).replace(/[&<>"']/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));}function today(n=0){const d=new Date();d.setDate(d.getDate()+n);return d.toISOString().slice(0,10);}ensureLogin().then(u=>{if(!u)return;username.textContent=u.username||'-';role.textContent=u.role==='ADMIN'?'管理员':'普通用户';phone.value=u.phone||'';email.value=u.email||'';});async function saveProfile(){const r=await fetch(ctx+'/api/auth/profile',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:phone.value,email:email.value,oldPassword:oldPassword.value,newPassword:newPassword.value})});const d=await r.json();profileMsg.textContent=d.message||'已保存';oldPassword.value='';newPassword.value='';}</script><script src="<%= ctx %>/static/js/global-search.js?v=20260616-fixed"></script></body></html>