<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><%--
    ============================================================
    routes.jsp — 路线规划页面
    
    页面功能：
    1. 根据用户输入的出发地、目的地、预算、天数、兴趣点推荐旅游路线。
    2. 展示系统推荐的路线列表，每条路线包含：名称、城市、天数、预算、主题、描述、包含景点。
    3. 支持查看路线详情，并一键进入酒店预订和门票预订页面。
    4. 从 AI 行程助手页面（ai.jsp）跳转时，自动携带城市、预算、天数参数。
    
    后端 API：
    - GET /api/auth/me — 鉴权。
    - GET /api/route/list?city=xxx&budget=xxx&days=xxx — 获取符合条件的推荐路线。
    ============================================================
--%>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>路线规划 - 智旅旅行</title><link rel="stylesheet" href="<%= ctx %>/static/css/ctrip-shell.css?v=20260616-fixed"></head><body><div class="app-shell"><aside class="side-nav"><button class="menu-toggle" title="&#33756;&#21333;">&#9776;</button><a class="side-link " href="<%= ctx %>/home.jsp"><span class="side-icon">⌂</span>首页</a><a class="side-link active" href="<%= ctx %>/routes.jsp"><span class="side-icon">▣</span>路线规划</a><a class="side-link " href="<%= ctx %>/hotels.jsp"><span class="side-icon">▣</span>酒店预订</a><a class="side-link " href="<%= ctx %>/tickets.jsp"><span class="side-icon">▤</span>门票·活动</a><a class="side-link " href="<%= ctx %>/map.jsp"><span class="side-icon">⌖</span>旅游地图</a><a class="side-link " href="<%= ctx %>/ai.jsp"><span class="side-icon">✦</span>AI行程助手</a><div class="side-divider"></div><a class="side-link " href="<%= ctx %>/orders.jsp"><span class="side-icon">☰</span>我的订单</a><a class="side-link " href="<%= ctx %>/profile.jsp"><span class="side-icon">☺</span>个人中心</a><button class="side-link" onclick="logout()"><span class="side-icon">&#8618;</span>退出登录</button></aside><main class="main-area"><header class="top-header"><a class="brand" href="<%= ctx %>/home.jsp"><span class="brand-mark">✦</span>智旅旅行</a><div class="global-search"><input id="topKeyword" placeholder="搜索任何旅游相关" onkeydown="if(event.key==='Enter')topSearch()"><button onclick="topSearch()">⌕</button></div><div class="top-actions"><span class="user-chip" id="userChip">用户中心</span><a href="<%= ctx %>/orders.jsp">我的订单</a><a href="<%= ctx %>/ai.jsp">联系客服</a><button onclick="logout()">退出</button></div></header><section class="page-content"><div class="hero-panel"><h1>AI 路线规划</h1><p>根据出发地、目的地、预算、天数和兴趣点推荐路线，并串联交通、酒店、门票和地图。</p></div><div class="panel"><div class="form-grid"><label>出发地<input id="origin" value="厦门"></label><label>目的地<input id="city" value="上海"></label><label>预算<input id="budget" type="number" value="1588"></label><label>天数<input id="days" type="number" value="3"></label><label>兴趣关键词<input id="interests" value="美食,夜景"></label></div><div class="action-row"><button class="primary" onclick="loadRoutes()">智能推荐路线</button><button class="secondary" onclick="location.href=ctx+'/ai.jsp?city='+encodeURIComponent(city.value)">进入AI规划</button></div></div><div id="result" class="result-grid"></div></section></main></div><script>const ctx='<%= ctx %>';async function ensureLogin(){const r=await fetch(ctx+'/api/auth/me');const d=await r.json();if(d.code!==200){location.href=ctx+'/login.jsp';return null;}const u=d.data||{};const c=document.getElementById('userChip');if(c)c.textContent='尊敬的，'+(u.username||'用户');return u;}async function logout(){await fetch(ctx+'/api/auth/logout',{method:'POST'});location.href=ctx+'/login.jsp';}function topSearch(){const kw=(document.getElementById('topKeyword')?.value||'上海').trim();location.href=ctx+'/search.jsp?q='+encodeURIComponent(kw||'上海');}function e(t){return String(t==null?'':t).replace(/[&<>"']/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));}function today(n=0){const d=new Date();d.setDate(d.getDate()+n);return d.toISOString().slice(0,10);}ensureLogin();const params=new URLSearchParams(location.search);city.value=params.get('city')||city.value;budget.value=params.get('budget')||budget.value;days.value=params.get('days')||days.value;async function loadRoutes(){result.innerHTML='<div class="card muted">正在生成路线...</div>';const body={originCity:origin.value,destinationCity:city.value,city:city.value,budget:budget.value,days:days.value,interests:(interests.value||'').split(/[,，]/).map(x=>x.trim()).filter(Boolean)};const r=await fetch(ctx+'/api/route/recommend',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});const d=await r.json();const list=d.data||[];result.innerHTML=list.map((x,i)=>{const spotArr=(x.spots&&x.spots.length?x.spots:(x.scenicOrder||x.scenicList||[]));const spots=spotArr.map(s=>s.scenicName||s.name||s).join(',');const hotel=x.hotel||x.recommendedHotel||{};const price=Number(x.totalPrice||x.estimatedCost||budget.value||1588);const routeTitle=x.routeName||('推荐路线'+(i+1));const mapUrl=ctx+'/map.jsp?city='+encodeURIComponent(city.value)+'&route='+encodeURIComponent(routeTitle)+'&spots='+encodeURIComponent(spots)+'&from=route';return '<div class="card"><div class="title">'+e(x.routeName||('智能推荐路线 '+(i+1)))+'</div><div class="muted">'+e(x.description||'按预算、天数和兴趣点生成的推荐路线。')+'</div><p><strong>交通与路费：</strong>'+e(origin.value)+' → '+e(city.value)+'，高铁/机票预估 ¥'+Math.round(price*.28)+'</p><p><strong>酒店住宿：</strong>'+e(hotel.hotelName||hotel.name||city.value+'精选酒店')+'，约 ¥'+Math.round(price*.38)+'</p><p><strong>景点与门票：</strong>'+e(spots||'核心景点 + 当地体验')+'，约 ¥'+Math.round(price*.22)+'</p><p><strong>预算拆分：</strong>总预算约 ¥'+price+'，餐饮交通预留 ¥'+Math.round(price*.12)+'</p><div class="action-row"><a class="primary" href="'+ctx+'/hotels.jsp?city='+encodeURIComponent(city.value)+'">预订该酒店</a><a class="secondary" href="'+ctx+'/tickets.jsp?city='+encodeURIComponent(city.value)+'">查看门票</a><a class="secondary" href="'+mapUrl+'">地图看路线</a></div></div>';}).join('')||'<div class="card muted">暂无路线，请换个目的地试试。</div>';}loadRoutes();</script><script src="<%= ctx %>/static/js/global-search.js?v=20260616-fixed"></script>
<!-- 页面主体结束 -->
</body></html>