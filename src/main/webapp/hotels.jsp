<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" language="java" isELIgnored="true" %><% String ctx=request.getContextPath(); %><!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>酒店预订 - 智旅旅行</title><link rel="stylesheet" href="<%= ctx %>/static/css/ctrip-shell.css?v=20260616-hotel-select"><style>.hotel-toolbar{background:#fff;border:1px solid #e5edf6;border-radius:22px;padding:22px;box-shadow:0 12px 30px rgba(20,40,80,.06);margin-bottom:20px}.hotel-list{display:grid;grid-template-columns:repeat(2,minmax(360px,1fr));gap:18px}.hotel-card{position:relative;transition:.18s ease;min-height:280px}.hotel-card.selected{border:2px solid #0b8ff6;box-shadow:0 20px 48px rgba(11,143,246,.18);transform:translateY(-2px)}.hotel-card.selected:after{content:'已选酒店';position:absolute;right:16px;top:16px;background:#0b8ff6;color:#fff;border-radius:999px;padding:6px 12px;font-size:13px;font-weight:900}.room-list{display:grid;gap:12px;margin-top:14px}.room-card{position:relative;border:1px solid #e5edf6;border-radius:18px;padding:18px;background:#fff;transition:.18s ease}.room-card.selected{border:2px solid #0b8ff6;background:#f4f9ff;box-shadow:0 12px 32px rgba(11,143,246,.14)}.room-card.disabled{opacity:.55;background:#f8fafc}.room-head{display:flex;justify-content:space-between;gap:12px;align-items:start;padding-right:0}.room-title{font-size:20px;font-weight:900}.room-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.select-btn.selected{background:#0b8ff6;color:#fff}.selected-summary{margin-top:12px;padding:12px 14px;border-radius:14px;background:#eef6ff;color:#0b7de3;font-weight:900}.empty-hotel{min-height:190px;display:flex;align-items:center;justify-content:center;border:1px dashed #cfe4fb;border-radius:18px;color:#667085}.status-ok{color:#059669;font-weight:900}.status-warn{color:#f97316;font-weight:900}@media(max-width:1100px){.hotel-list{grid-template-columns:1fr}}</style></head><body><div class="app-shell"><aside class="side-nav"><button class="menu-toggle" title="&#33756;&#21333;">&#9776;</button><a class="side-link " href="<%= ctx %>/home.jsp"><span class="side-icon">⌂</span>首页</a><a class="side-link " href="<%= ctx %>/routes.jsp"><span class="side-icon">▣</span>路线规划</a><a class="side-link active" href="<%= ctx %>/hotels.jsp"><span class="side-icon">▣</span>酒店预订</a><a class="side-link " href="<%= ctx %>/tickets.jsp"><span class="side-icon">▤</span>门票·活动</a><a class="side-link " href="<%= ctx %>/map.jsp"><span class="side-icon">⌖</span>旅游地图</a><a class="side-link " href="<%= ctx %>/ai.jsp"><span class="side-icon">✦</span>AI行程助手</a><div class="side-divider"></div><a class="side-link " href="<%= ctx %>/orders.jsp"><span class="side-icon">☰</span>我的订单</a><a class="side-link " href="<%= ctx %>/profile.jsp"><span class="side-icon">☺</span>个人中心</a><button class="side-link" onclick="logout()"><span class="side-icon">&#8618;</span>退出登录</button></aside><main class="main-area"><header class="top-header"><a class="brand" href="<%= ctx %>/home.jsp"><span class="brand-mark">✦</span>智旅旅行</a><div class="global-search"><input id="topKeyword" placeholder="搜索城市、景点、酒店" onkeydown="if(event.key==='Enter')topSearch()"><button onclick="topSearch()">⌕</button></div><div class="top-actions"><span class="user-chip" id="userChip">用户中心</span><a href="<%= ctx %>/orders.jsp">我的订单</a><a href="<%= ctx %>/ai.jsp">联系客服</a><button onclick="logout()">退出</button></div></header><section class="page-content"><div class="hero-panel"><h1>酒店可视化预订</h1><p>选择酒店和房型后会出现蓝色选中态，并在提交订单前明确展示当前锁定的房源。</p></div><div class="hotel-toolbar"><div class="form-grid"><label>城市<input id="city" value="上海"></label><label>入住日期<input id="checkIn" type="date"></label><label>退房日期<input id="checkOut" type="date"></label></div><div class="action-row"><button class="primary" onclick="loadHotels()">查询酒店</button><button class="secondary" onclick="createOrder()">提交酒店订单</button><a class="secondary" href="<%= ctx %>/map.jsp">打开地图</a></div><div id="selectedTip" class="selected-summary">请选择酒店房型后提交订单。</div></div><div id="hotels" class="hotel-list"></div></section></main></div><script>const ctx='<%= ctx %>';async function ensureLogin(){const r=await fetch(ctx+'/api/auth/me');const d=await r.json();if(d.code!==200){location.href=ctx+'/login.jsp';return null;}const u=d.data||{};userChip.textContent='尊敬的，'+(u.username||'用户');return u;}async function logout(){await fetch(ctx+'/api/auth/logout',{method:'POST'});location.href=ctx+'/login.jsp';}function topSearch(){const kw=(topKeyword.value||city.value||'上海').trim();location.href=ctx+'/search.jsp?q='+encodeURIComponent(kw)}function e(t){return String(t==null?'':t).replace(/[&<>"']/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));}function pad(n){return String(n).padStart(2,'0')}function fmt(d){return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate())}function today(n=0){const d=new Date();d.setDate(d.getDate()+n);return fmt(d)}const params=new URLSearchParams(location.search);let selectedRoom=null;let hotelsData=[];ensureLogin();city.value=params.get('city')||city.value;checkIn.value=today(1);checkOut.value=today(3);function markSelected(){document.querySelectorAll('.hotel-card').forEach(card=>card.classList.toggle('selected',selectedRoom&&card.dataset.hotelId==selectedRoom.hotelId));document.querySelectorAll('.room-card').forEach(card=>card.classList.toggle('selected',selectedRoom&&card.dataset.roomId==selectedRoom.roomId));document.querySelectorAll('.select-btn').forEach(btn=>{const on=selectedRoom&&btn.dataset.roomId==selectedRoom.roomId;btn.classList.toggle('selected',on);btn.textContent=on?'已选择':'选择房型';});}async function loadHotels(){selectedRoom=null;selectedTip.textContent='请选择酒店房型后提交订单。';hotels.innerHTML='<div class="card muted">正在查询酒店...</div>';const r=await fetch(ctx+'/api/hotel/list?city='+encodeURIComponent(city.value));const d=await r.json();hotelsData=d.data||[];hotels.innerHTML=hotelsData.map(h=>'<div class="card hotel-card" data-hotel-id="'+h.id+'"><div class="title">'+e(h.hotelName||h.name)+'</div><div class="muted">'+e(h.city||'')+' &middot; '+e(h.address||'')+'</div><div class="price" id="hotel-price-'+h.id+'">&#27491;&#22312;&#35745;&#31639;&#26368;&#20302;&#20215;</div><div class="action-row"><span class="secondary">房态已展开</span><a class="secondary" href="'+ctx+'/map.jsp?city='+encodeURIComponent(h.city||city.value)+'&q='+encodeURIComponent(h.hotelName||h.name)+'">地图定位</a></div><div id="rooms-'+h.id+'" class="room-list"><div class="empty-hotel">正在加载房型和实时房态...</div></div></div>').join('')||'<div class="card muted">当前城市暂无酒店。</div>';await Promise.all(hotelsData.map(h=>loadRooms(h.id,h.hotelName||h.name)));}async function loadRooms(hotelId,hotelName){const box=document.getElementById('rooms-'+hotelId);box.innerHTML='<div class="muted">正在加载房态...</div>';const r=await fetch(ctx+'/api/hotel/room-availability?hotelId='+hotelId+'&checkInDate='+checkIn.value+'&checkOutDate='+checkOut.value);const d=await r.json();const list=d.data||[];const minPrice=list.reduce((min,x)=>{const room=x.room||x;const price=Number(room.price||0);return price>0&&price<min?price:min;},Infinity);const hotelPrice=document.getElementById('hotel-price-'+hotelId);if(hotelPrice)hotelPrice.innerHTML=isFinite(minPrice)?'&yen;'+minPrice+'&#36215;':'&#26242;&#26080;&#25253;&#20215;';box.innerHTML=list.map(x=>{const room=x.room||x;const left=x.availableCount??x.leftCount??room.stock??0;const full=left<=0;const roomName=room.roomType||room.roomName||'标准房';return '<div class="room-card '+(full?'disabled':'')+'" data-room-id="'+room.id+'"><div class="room-head"><div><div class="room-title">'+e(roomName)+'</div><div class="muted">房态：<span class="'+(full?'status-warn':'status-ok')+'">'+(full?'满房':'剩余 '+left+' 间')+'</span></div></div><div class="price">¥'+(room.price||0)+'<small>/晚</small></div></div><div class="room-actions"><button class="secondary select-btn" data-room-id="'+room.id+'" '+(full?'disabled':'')+' onclick="selectRoom('+hotelId+','+room.id+',\''+e(hotelName)+'\',\''+e(roomName)+'\')">选择房型</button></div></div>';}).join('')||'<div class="empty-hotel">暂无可订房型。</div>';markSelected();}function selectRoom(hotelId,roomId,hotelName,roomName){selectedRoom={hotelId,roomId,hotelName,roomName};selectedTip.textContent='已选择：'+hotelName+' · '+roomName+'（'+checkIn.value+' 至 '+checkOut.value+'）';markSelected();}async function createOrder(){if(!selectedRoom){alert('请先选择酒店房型');return;}const r=await fetch(ctx+'/api/order/hotel/create',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({hotelId:selectedRoom.hotelId,roomId:selectedRoom.roomId,checkInDate:checkIn.value,checkOutDate:checkOut.value})});const d=await r.json();alert(d.message||'已创建酒店订单');if(d.code===200)location.href=ctx+'/orders.jsp';}loadHotels();</script><script src="<%= ctx %>/static/js/global-search.js?v=20260616-hotel-select"></script></body></html>